# ============================================================
#  ClearFox — Environment Variables
#  License key, AI model keys, and authentication are configured
#  in the setup wizard (http://localhost:3000 after first start).
# ============================================================

# Port for ClearFox UI (change if 3000 is busy)
# CLEARFOX_PORT=3000

# Domain for HTTPS (optional). Caddy auto-obtains a Let's Encrypt certificate.
# Requires ports 80 and 443 open and DNS pointing to this server.
# CLEARFOX_DOMAIN=ai.yourcompany.com

# ============================================================
#  install.sh fills the two keys below with random values on first
#  run and writes them to .env. They are generated on YOUR server and
#  never sent anywhere. Keep .env safe — losing these keys means
#  secrets stored in the database become unreadable.
# ============================================================

# Encryption key for secrets stored in MongoDB (AES-256).
# PORTAL_SECRETS_KEY=

# Internal API key for service-to-service auth (portal ↔ MCP servers, agent scheduler).
# PORTAL_INTERNAL_AUTH_KEY=
